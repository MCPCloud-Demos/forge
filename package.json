{
  "name": "forge",
  "version": "1.0.0",
  "description": "Forge — Code & Issues API (GitHub-style GraphQL look-alike for the MCPCloud showcase)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx prisma db push --skip-generate && bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "seed": "bun run src/seed.ts",
    "db:push": "bunx prisma db push",
    "generate": "bunx prisma generate",
    "test": "bun test",
    "postinstall": "bunx prisma generate"
  },
  "dependencies": {
    "@apollo/server": "^4.11.2",
    "@prisma/client": "^6.2.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "graphql": "^16.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3"
  }
}
