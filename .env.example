# Forge configuration. Copy to .env for local overrides.

# Postgres connection string. Defaults to the docker-compose database.
# On Fly.io this is set automatically by the attached Postgres cluster.
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

# Demo OAuth access token accepted in the `Authorization: Bearer <token>`
# header. Intentionally public — a read-mostly demo credential.
FORGE_DEMO_TOKEN=forge_demo_token_8b3f1d6a2c9e4057

# The single demo OAuth client for the `POST /oauth/token` endpoint
# (grant_type=client_credentials).
FORGE_CLIENT_ID=forge-demo-client
FORGE_CLIENT_SECRET=forge_demo_secret_5e2a9c7b1f4d8063

# Re-seed the database with demo data on startup when it is empty.
SEED_ON_STARTUP=true

# Traffic generator: a background loop that periodically runs GraphQL
# operations so the deployed demo always shows live activity. Enabled on the
# Fly deployment; off locally so dev/tests don't start a background loop.
ENABLE_TRAFFIC_GENERATOR=false
TRAFFIC_INTERVAL_SECONDS=180
TRAFFIC_TARGET_URL=http://127.0.0.1:8080
